<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clinic.app.PatientController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Μητρώο Ασθενών" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #dcdde1;">
        <TextField fx:id="txtName" promptText="Ονοματεπώνυμο" HBox.hgrow="ALWAYS" />
        <TextField fx:id="txtPhone" promptText="Τηλέφωνο" prefWidth="150"/>
        <TextField fx:id="txtAmka" promptText="ΑΜΚΑ" prefWidth="150"/>
        <Button text="Αποθήκευση" onAction="#addPatient" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TextField fx:id="searchField" promptText="🔍 Αναζήτηση ασθενή με όνομα ή ΑΜΚΑ..." style="-fx-pref-height: 35;"/>

    <TableView fx:id="patientsTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colName" text="ΟΝΟΜΑΤΕΠΩΝΥΜΟ" minWidth="200" prefWidth="400"/>
            <TableColumn fx:id="colPhone" text="ΤΗΛΕΦΩΝΟ" minWidth="120" prefWidth="180"/>
            <TableColumn fx:id="colAmka" text="ΑΜΚΑ" minWidth="120" prefWidth="180"/>
            <TableColumn fx:id="colAction" text="EDIT" minWidth="60" maxWidth="80" prefWidth="70" style="-fx-alignment: CENTER;"/>
        </columns>
    </TableView>
</VBox>