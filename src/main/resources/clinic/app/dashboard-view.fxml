<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" style="-fx-background-color: #f1f2f6; -fx-padding: 25;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clinic.app.DashboardController">

    <Label text="Κεντρικός Πίνακας Ελέγχου" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

    <HBox spacing="20.0" alignment="CENTER">
        <children>
            <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <Label text="👨‍⚕️ Γιατροί" style="-fx-text-fill: #7f8c8d;"/>
                <Label fx:id="lblTotalDoctors" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
            </VBox>
            <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <Label text="👥 Ασθενείς" style="-fx-text-fill: #7f8c8d;"/>
                <Label fx:id="lblTotalPatients" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>
            </VBox>
            <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <Label text="📅 Ραντεβού" style="-fx-text-fill: #7f8c8d;"/>
                <Label fx:id="lblRangeAppts" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
            </VBox>
        </children>
    </HBox>

    <Separator />

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Πρόγραμμα Περιόδου:" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
        <Label text="Από:" />
        <DatePicker fx:id="dateFrom" prefWidth="150" />
        <Label text="Έως:" />
        <DatePicker fx:id="dateTo" prefWidth="150" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <TableView fx:id="dailyTable" VBox.vgrow="ALWAYS" prefHeight="300">
        <columns>
            <TableColumn fx:id="colDate" text="ΗΜΕΡΟΜΗΝΙΑ" prefWidth="110" />
            <TableColumn fx:id="colTime" text="ΩΡΑ" prefWidth="80" />
            <TableColumn fx:id="colPatient" text="ΑΣΘΕΝΗΣ" prefWidth="180" />
            <TableColumn fx:id="colDoctor" text="ΙΑΤΡΟΣ" prefWidth="180" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox spacing="20" prefHeight="250">
        <children>
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📝 ΣΗΜΕΙΩΣΕΙΣ ΓΡΑΜΜΑΤΕΙΑΣ" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <DatePicker fx:id="commentsDatePicker" prefWidth="130" style="-fx-font-size: 11px;" />
                </HBox>
                <ListView fx:id="listComments" VBox.vgrow="ALWAYS" />
                <HBox spacing="10">
                    <Button text="ΠΡΟΣΘΗΚΗ" onAction="#addComment" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
                    <Button text="ΕΠΕΞΕΡΓΑΣΙΑ" onAction="#editComment" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
                    <Button text="ΔΙΑΓΡΑΦΗ" onAction="#deleteComment" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
                </HBox>
            </VBox>

            <VBox spacing="10" prefWidth="350" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="👨‍⚕️ ΠΑΡΟΥΣΙΟΛΟΓΙΟ ΓΙΑΤΡΩΝ" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                    <Region HBox.hgrow="ALWAYS" />

                    <!-- ΕΔΩ ΜΠΑΙΝΕΙ ΤΟ LABEL ΓΙΑ ΤΟ ΜΗΝΥΜΑ -->
                    <Label fx:id="notificationAttendanceLabel" visible="false" style="-fx-font-size: 11px; -fx-font-weight: bold;" />

                    <Button fx:id="btnSaveAttendance" onAction="#saveAttendanceClick" text="ΑΠΟΘΗΚΕΥΣΗ"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 10px; -fx-font-weight: bold;" />
                </HBox>
                <TableView fx:id="attendanceTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colAttendanceName" text="ΓΙΑΤΡΟΣ" prefWidth="200" />
                        <TableColumn fx:id="colAttendanceStatus" text="ΠΑΡΩΝ" prefWidth="80" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </children>
    </HBox>

</VBox>

