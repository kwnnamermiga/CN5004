<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" style="-fx-background-color: #f1f2f6; -fx-padding: 25;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clinic.app.DashboardController">

    <Label text="Κεντρικός Πίνακας Ελέγχου" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

    <HBox spacing="20.0" alignment="CENTER">
        <children>
            <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <Label text="👨‍⚕️ Γιατροί" style="-fx-text-fill: #7f8c8d;"/>
                <Label fx:id="lblTotalDoctors" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
            </VBox>
            <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <Label text="👥 Ασθενείς" style="-fx-text-fill: #7f8c8d;"/>
                <Label fx:id="lblTotalPatients" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>
            </VBox>
            <VBox alignment="CENTER" prefWidth="180" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <Label text="📅 Ραντεβού" style="-fx-text-fill: #7f8c8d;"/>
                <Label fx:id="lblRangeAppts" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
            </VBox>
        </children>
    </HBox>

    <Separator />

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Πρόγραμμα Περιόδου:" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
        <Label text="Από:" />
        <DatePicker fx:id="dateFrom" prefWidth="150" />
        <Label text="Έως:" />
        <DatePicker fx:id="dateTo" prefWidth="150" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <TableView fx:id="dailyTable" VBox.vgrow="ALWAYS" prefHeight="300">
        <columns>
            <TableColumn fx:id="colDate" text="ΗΜΕΡΟΜΗΝΙΑ" prefWidth="110" />
            <TableColumn fx:id="colTime" text="ΩΡΑ" prefWidth="80" />
            <TableColumn fx:id="colPatient" text="ΑΣΘΕΝΗΣ" prefWidth="180" />
            <TableColumn fx:id="colDoctor" text="ΙΑΤΡΟΣ" prefWidth="180" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Αυτό το HBox θα απλωθεί σε όλο το πλάτος, όπως ο πίνακας -->
    <HBox spacing="0" VBox.vgrow="NEVER" prefHeight="320">
        <children>

            <!-- 1. ΣΗΜΕΙΩΣΕΙΣ: Καταλαμβάνει το 26% (Ημερομηνία + Ώρα) -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10 0 0 10; -fx-border-color: #dcdde1; -fx-border-width: 1 1 1 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <HBox alignment="CENTER_RIGHT" minHeight="20">
                    <Label fx:id="notificationNotesLabel" visible="false" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                </HBox>
                <!-- Εδώ μειώνουμε το maxWidth δυναμικά για να ταιριάξει με τις 2 πρώτες στήλες -->
                <minWidth><Region fx:constant="USE_PREF_SIZE" /></minWidth>
                <prefWidth>300</prefWidth> <!-- Αυτό θα το ρυθμίσουμε αν χρειαστεί -->

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📝 ΣΗΜΕΙΩΣΕΙΣ" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <DatePicker fx:id="commentsDatePicker" prefWidth="110" style="-fx-font-size: 10px;" />
                </HBox>
                <ListView fx:id="listComments" VBox.vgrow="ALWAYS" />
                <HBox spacing="5">
                    <Button onAction="#addComment" text="+" prefWidth="35" style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
                    <Button onAction="#editComment" text="EDIT" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 10px;" />
                    <Button onAction="#deleteComment" text="DEL" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 10px;" />
                </HBox>
            </VBox>

            <!-- 2. ΠΑΡΟΥΣΙΟΛΟΓΙΟ: Καταλαμβάνει το υπόλοιπο 74% (Ασθενής + Γιατρός) -->
            <VBox spacing="0" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: white; -fx-padding: 0 15 15 15; -fx-background-radius: 0 10 10 0; -fx-border-color: #dcdde1; -fx-border-width: 1 1 1 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                <children>
                    <HBox alignment="CENTER_RIGHT" minHeight="25">
                        <Label fx:id="notificationAttendanceLabel" visible="false" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                    </HBox>
                    <VBox spacing="10" VBox.vgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="👨‍⚕️ ΠΑΡΟΥΣΙΟΛΟΓΙΟ ΓΙΑΤΡΩΝ" style="-fx-font-weight: bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnSaveAttendance" onAction="#saveAttendanceClick" text="ΑΠΟΘΗΚΕΥΣΗ" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" />
                        </HBox>
                        <TableView fx:id="attendanceTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colAttendanceName" text="ΓΙΑΤΡΟΣ" />
                                <TableColumn fx:id="colAttendanceStatus" text="ΠΑΡΩΝ" maxWidth="100" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </children>
            </VBox>
        </children>
    </HBox>

</VBox>

