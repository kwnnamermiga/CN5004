<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clinic.app.controllers.MainController">
    <left>
        <VBox prefWidth="230.0" spacing="10.0" style="-fx-background-color: #2c3e50;">
            <padding> <Insets top="40.0" /> </padding>
            <children>
                <Label text="AEGEAN HEALTH" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 20;">
                    <VBox.margin> <Insets bottom="20.0" left="20.0" /> </VBox.margin>
                </Label>

                <Button fx:id="btnDashboard" text="🏠  Αρχική" onAction="#handleNavigation" maxWidth="Infinity" prefHeight="50.0" styleClass="menu-button" />
                <Button fx:id="btnAppointments" text="📅  Ραντεβού" onAction="#handleNavigation" maxWidth="Infinity" prefHeight="50.0" styleClass="menu-button" />
                <Button fx:id="btnPatients" text="👥  Ασθενείς" onAction="#handleNavigation" maxWidth="Infinity" prefHeight="50.0" styleClass="menu-button" />
                <Button fx:id="btnDoctors" text="👨‍⚕️  Ιατροί" onAction="#handleNavigation" maxWidth="Infinity" prefHeight="50.0" styleClass="menu-button" />
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f5f6fa;" />
    </center>
</BorderPane>