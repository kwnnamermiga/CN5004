<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clinic.app.DoctorController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Διαχείριση Ιατρικού Προσωπικού" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #dcdde1;">
        <TextField fx:id="txtName" promptText="Ονοματεπώνυμο" HBox.hgrow="ALWAYS" />
        <TextField fx:id="txtSpecialty" promptText="Ειδικότητα" prefWidth="150"/>
        <TextField fx:id="txtPhone" promptText="Τηλέφωνο" prefWidth="120"/>
        <Label text="Χρώμα:"/>
        <ColorPicker fx:id="colorPicker" />
        <Button text="Αποθήκευση" onAction="#addDoctor" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TableView fx:id="doctorsTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colColor" text="ΧΡΩΜΑ" minWidth="60" maxWidth="80" prefWidth="70" style="-fx-alignment: CENTER;"/>

            <TableColumn fx:id="colName" text="ΟΝΟΜΑΤΕΠΩΝΥΜΟ" minWidth="150" prefWidth="300" />

            <TableColumn fx:id="colSpecialty" text="ΕΙΔΙΚΟΤΗΤΑ" minWidth="120" prefWidth="200" />

            <TableColumn fx:id="colPhone" text="ΤΗΛΕΦΩΝΟ" minWidth="100" prefWidth="150" />

            <TableColumn fx:id="colAction" text="EDIT" minWidth="60" maxWidth="80" prefWidth="70" style="-fx-alignment: CENTER;"/>
        </columns>
    </TableView>
</VBox>